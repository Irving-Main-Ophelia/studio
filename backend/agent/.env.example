# Copy to .env and fill in your keys. .env is gitignored.

# Anthropic — required for the chat agent.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: a cheaper/faster model for routine tool calls.
ANTHROPIC_MODEL=claude-sonnet-4-6-20251022

# Optional: where the agent backend listens.
STOCKHAUSEN_AGENT_HOST=127.0.0.1
STOCKHAUSEN_AGENT_PORT=8000

# Logging
LOG_LEVEL=info
