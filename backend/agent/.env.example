# Copy to .env and fill in your keys. .env is gitignored.

# Anthropic — required for the chat agent.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Pin a specific model. As of June 2026 the current IDs are:
#   claude-fable-5       (most capable — GA since June 9 2026)
#   claude-opus-4-8      (second tier — complex reasoning, agentic coding)
#   claude-sonnet-4-6    (balanced)
#   claude-haiku-4-5-20251001  (fastest)
ANTHROPIC_MODEL=claude-fable-5

# Optional: where the agent backend listens.
STOCKHAUSEN_AGENT_HOST=127.0.0.1
STOCKHAUSEN_AGENT_PORT=8000

# Logging
LOG_LEVEL=info
